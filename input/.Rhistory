Comparison = c(
"mean(Observed) / mean(REKIS)",
"mean(REKIS) / mean(GCM_RCM_mean)",
"mean(Observed) / mean(GCM_RCM_mean)"
),
Value = c(
mean(wide_plot$Observed[wide_plot$Observed > min_ref], na.rm = TRUE) /
mean(wide_plot$REKIS[wide_plot$Observed > min_ref],   na.rm = TRUE),
mean(wide_plot$REKIS[wide_plot$REKIS > min_ref], na.rm = TRUE) /
mean(wide_plot$GCM_RCM_mean[wide_plot$REKIS > min_ref], na.rm = TRUE),
mean(wide_plot$Observed[wide_plot$Observed > min_ref], na.rm = TRUE) /
mean(wide_plot$GCM_RCM_mean[wide_plot$Observed > min_ref], na.rm = TRUE)
)
)
ratio_text <- paste0(
ratios_plot$Comparison, ": ",
format(round(ratios_plot$Value, 2), nsmall = 2),
collapse = "\n"
)
# ---------------------------
# Plot (3 lines)
# ---------------------------
x_annot <- min(plot_df$Date) + 0.02 * diff(range(plot_df$Date))
y_annot <- max(plot_df$Total, na.rm = TRUE) * 0.98
p <- ggplot(plot_df, aes(Date, Total, color = Source, group = Source)) +
geom_line(linewidth = 0.9) +
theme_minimal() +
theme(legend.position = "bottom") +
labs(
title = paste0("Total Discharge: Observed vs REKIS vs Mean(GCM_RCM) — ", rcp),
subtitle = "Mean ratios annotated on plot",
x = "Date",
y = "Total discharge (Q)",
color = "Source"
) +
annotate(
"text",
x = x_annot, y = y_annot,
hjust = 0, vjust = 1,
label = ratio_text,
size = 3.5
)
print(p)
print(gcm_table)
gc()
library(dplyr)
library(lubridate)
library(ggplot2)
mol_mass_TP <- 30.97 # g/mole
df_all <- data.frame()
df_annual <- data.frame()
setwd("/home/muhammed/Projects/Mews_Data_Ohra/Processed_data/Projections_Stauinhalt_RCP_Szenarien/GOTM_INPUT/")
rcp_dirs <- list.dirs(path = paste0("./"), recursive = F, full.names = F)
for(r in rcp_dirs){
model_dirs <- list.dirs(path = paste0("./",  r), recursive = F, full.names = F)
for( m in model_dirs){
in_files <- list.files(path = paste("." ,r,m, sep="/"), pattern = "In" )
in_files <- in_files[!in_files %in% "Inflow_Extra.dat"]
# Initialize a data frame to store all stream data
all_streams_data <- data.frame(X.date = as.Date(character()), P_load = numeric(), Stream = character())
# Loop through each inflow file
for (file in in_files) {
dd <- read.table( file = paste(".",  r,m,file, sep="/"), sep = "\t", header = TRUE)
dd$P_load <- dd$TP * mol_mass_TP * dd$q * 86400 * 1e-6
dd$Stream <- file  # Add a column for the stream name
dd$X.date <- as.Date(dd$X.date)
# Filter for dates after 2014
# dd <- dd %>% filter(year(X.date) > 2014)
# Append to the combined data frame
all_streams_data <- bind_rows(all_streams_data, dd)
}
# Calculate total P load across all streams for each date after 2014
total_daily_P_load <- all_streams_data %>%
group_by(X.date) %>%
summarise(P_load = sum(P_load, na.rm = TRUE), .groups = "drop") %>%
mutate(Stream = "Total")
# Combine stream data and total data
all_streams_data <- bind_rows(all_streams_data, total_daily_P_load)
#Calculate annual P loading for each stream and year
annual_loading <- all_streams_data %>%
mutate(Year = year(X.date)) %>%  # Extract year from date
#  filter(Year > 2004) %>%  # Filter for years after 2014
group_by(Stream, Year) %>%  # Group by stream and year
summarise(Annual_P_Load = sum(P_load, na.rm = TRUE), .groups = "drop")  # Sum P load for each group
# Time Series Plot (after 2014)
annual_avg_all <- annual_loading %>% group_by(Stream) %>%
summarise(Annual_mean_P_Load = mean(Annual_P_Load, na.rm = TRUE), .groups = "drop")
annual_avg_all$rcp <- r
annual_avg_all$gcm_rcm <- m
df_all  <- rbind(df_all, annual_avg_all)
annual_loading$rcp <- r
annual_loading$gcm_rcm <- m
df_annual  <- rbind(df_annual, annual_loading)
}
}
df_total <- df_annual %>% filter(Stream == "Total")
p_gcm <- ggplot(df_total, aes(x = Year, y = Annual_P_Load, color = gcm_rcm)) +
geom_line(linewidth = 0.7) +
geom_point(size = 1.5, alpha = 0.7) +
facet_wrap(~ rcp, nrow = 1) +
labs(
title = "Annual Phosphorus Load (Total of all streams) by RCP and GCM-RCM",
x = "Year",
y = "Annual P Load (kg/year)",
color = "Model"
) +
theme_minimal() +
theme(
legend.position = "bottom",
axis.text.x = element_text(angle = 45, hjust = 1),
strip.background = element_rect(fill = "lightgray", color = "gray")
)
p_gcm
# Calculate the average Annual_P_Load for each RCP scenario and Year
df_avg_by_rcp <- df_total %>%
group_by(rcp, Year) %>%
summarise(Avg_Annual_P_Load = mean(Annual_P_Load, na.rm = TRUE), .groups = "drop")
# Plot the averaged data
p_rcp_av <- ggplot(df_avg_by_rcp, aes(x = Year, y = Avg_Annual_P_Load, color = rcp)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
labs(
