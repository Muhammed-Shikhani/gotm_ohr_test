library(dplyr)
library(lubridate)
library(ggplot2)
setwd("/home/muhammed/Projects/Mews_Data_Ohra/GOTM/GOTM_obs_hydrology_ERA5_4groups/input/")
# Define molecular masses
mol_mass_TP <- 30.97 # g/mole
# List of inflow files
in_files <- list.files(pattern = "Inflow")
# Initialize a data frame to store all stream data
all_streams_data <- data.frame(X.date = as.Date(character()), P_load = numeric(), Stream = character())
# Loop through each inflow file
for (file in in_files) {
dd <- read.table(file, sep = "\t", header = TRUE)
dd$P_load <- dd$TP * mol_mass_TP * dd$Q * 86400 * 1e-6 # mmol/m3 * g/mol * m3/s * s/day * mol/mmol * kg/g = kg/day
dd$Stream <- file  # Add a column for the stream name
dd$X.date <- as.Date(dd$X.date)
# Filter for dates after 2014
#  dd <- dd %>% filter(year(X.date) > 2014)
# Append to the combined data frame
all_streams_data <- bind_rows(all_streams_data, dd)
}
# Calculate total P load across all streams for each date after 2014
total_daily_P_load <- all_streams_data %>%
group_by(X.date) %>%
summarise(P_load = sum(P_load, na.rm = TRUE), .groups = "drop") %>%
mutate(Stream = "Total")
# Combine stream data and total data
all_streams_data <- bind_rows(all_streams_data, total_daily_P_load)
#Calculate annual P loading for each stream and year
annual_loading <- all_streams_data %>%
mutate(Year = year(X.date)) %>%  # Extract year from date
#filter(Year > 2014) %>%  # Filter for years after 2014
group_by(Stream, Year) %>%  # Group by stream and year
summarise(Annual_P_Load = sum(P_load, na.rm = TRUE), .groups = "drop")  # Sum P load for each group
#Calculate annual P loading for each stream and year
annual_total_loading <- total_daily_P_load%>%
mutate(Year = year(X.date)) %>%  # Extract year from date
# filter(Year > 2014) %>%  # Filter for years after 2014
group_by(Stream, Year) %>%  # Group by stream and year
summarise(Annual_P_Load = sum(P_load, na.rm = TRUE), .groups = "drop")  # Sum P load for each group
annual_avg_all <- annual_loading %>% group_by(Stream) %>%
summarise(Annual_mean_P_Load = mean(Annual_P_Load, na.rm = TRUE), .groups = "drop")
p <- ggplot(annual_total_loading, aes(x = Year, y = Annual_P_Load, color = Stream)) +
geom_point() +
labs(title = "Total annual Phosphorus Load of observed Q and Loadest C ", x = "Date", y = "P Load (kg/year)") +
theme_minimal() +
theme(legend.position = "bottom")
p
